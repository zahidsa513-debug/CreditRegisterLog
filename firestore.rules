rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isBasicAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isBasicAuth() && request.auth.uid == userId;
    }
    
    function isResourceOwner(id) {
      return isBasicAuth() && (
        (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid) || 
        (id is string && id.startsWith(request.auth.uid + '_'))
      );
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function isValidTimestamp(val) {
      return val is timestamp || val is string; // Allow ISO string or Timestamp
    }

    // --- Entity Validations ---

    function isValidArea(data) {
      return data.userId == request.auth.uid && 'name' in data;
    }

    function isValidCustomer(data) {
      return data.userId == request.auth.uid && 'name' in data;
    }

    function isValidSale(data) {
      return data.userId == request.auth.uid && 'type' in data;
    }

    function isValidExpense(data) {
      return data.userId == request.auth.uid && 'amount' in data;
    }

    function isValidSettings(data) {
      return data.userId == request.auth.uid;
    }

    function isValidCheck(data) {
      return data.userId == request.auth.uid && 'amount' in data;
    }

    function isValidProfile(data) {
      return data.uid == request.auth.uid && 'email' in data;
    }

    function isValidFeedback(data) {
      return data.userId == request.auth.uid && 'message' in data;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && incoming().email == request.auth.token.email;
    }

    match /profiles/{profileId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid || profileId.startsWith(request.auth.uid + '_'));
      allow create, update: if isSignedIn() && isValidId(profileId) && isValidProfile(incoming());
      allow delete: if isSignedIn() && (resource.data.uid == request.auth.uid || profileId.startsWith(request.auth.uid + '_'));
    }

    match /areas/{areaId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || areaId.startsWith(request.auth.uid + '_'));
      allow create, update: if isSignedIn() && isValidId(areaId) && isValidArea(incoming());
      allow delete: if isSignedIn() && isResourceOwner(areaId);
    }

    match /customers/{customerId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || customerId.startsWith(request.auth.uid + '_'));
      allow create, update: if isSignedIn() && isValidId(customerId) && isValidCustomer(incoming());
      allow delete: if isSignedIn() && isResourceOwner(customerId);
    }

    match /sales/{saleId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || saleId.startsWith(request.auth.uid + '_'));
      allow create, update: if isSignedIn() && isValidId(saleId) && isValidSale(incoming());
      allow delete: if isSignedIn() && isResourceOwner(saleId);
    }

    match /expenses/{expenseId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || expenseId.startsWith(request.auth.uid + '_'));
      allow create, update: if isSignedIn() && isValidId(expenseId) && isValidExpense(incoming());
      allow delete: if isSignedIn() && isResourceOwner(expenseId);
    }

    match /settings/{settingId} {
      allow get: if isOwner(settingId);
      allow create, update: if isOwner(settingId) && isValidSettings(incoming());
      allow delete: if isOwner(settingId);
    }

    match /checks/{checkId} {
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || checkId.startsWith(request.auth.uid + '_'));
      allow create, update: if isSignedIn() && isValidId(checkId) && isValidCheck(incoming());
      allow delete: if isSignedIn() && isResourceOwner(checkId);
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidId(feedbackId) && isValidFeedback(incoming());
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || feedbackId.startsWith(request.auth.uid + '_'));
    }
  }
}
